# Bonsai MCP — Environment Configuration
# Copy this file to .env and adjust for your setup.

# Path to the Bonsai-Image-Demo repo root (required).
# Default: ~/Projects/Bonsai-Image-Demo
# BONSAI_IMAGE_DEMO_DIR=/home/user/Bonsai-Image-Demo

# Where generated PNGs are written.
# Default: {BONSAI_IMAGE_DEMO_DIR}/outputs/mcp
# BONSAI_OUTPUT_DIR=/tmp/bonsai-outputs

# Override path to the wrapper subprocess script.
# Default: alongside server.py (src/bonsai_mcp/generate_wrapper.py)
# BONSAI_GENERATE_WRAPPER=/custom/path/generate_wrapper.py

# Default model variant when the tool caller doesn't specify one.
# Valid values: ternary-mlx, ternary-gemlite, binary-mlx, binary-gemlite
# Default: auto-detected by platform (ternary-mlx on macOS, ternary-gemlite on Linux)
# BONSAI_MODEL=ternary-mlx
